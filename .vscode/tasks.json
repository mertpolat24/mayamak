{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Start Static Server",
      "type": "shell",
      "command": "python scripts/dev-server.py",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "isBackground": true,
      "problemMatcher": {
        "owner": "static-server",
        "pattern": { "regexp": "^.*$" },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "Clean URLs enabled",
          "endsPattern": "Clean URLs enabled"
        }
      },
      "presentation": {
        "reveal": "silent",
        "panel": "shared",
        "showReuseMessage": false
      }
    }
  ]
}
